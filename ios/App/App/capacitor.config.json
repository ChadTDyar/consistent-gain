{
	"appId": "com.chad.momentumfit",
	"appName": "Momentum: Fitness Tracker",
	"webDir": "dist",
	"server": {
		"androidScheme": "https"
	},
	"plugins": {
		"PushNotifications": {
			"presentationOptions": [
				"badge",
				"sound",
				"alert"
			]
		},
		"StatusBar": {
			"style": "dark"
		}
	},
	"packageClassList": [
		"AppPlugin",
		"CAPBrowserPlugin",
		"HapticsPlugin",
		"LocalNotificationsPlugin",
		"PreferencesPlugin",
		"PushNotificationsPlugin",
		"StatusBarPlugin",
		"CapacitorHealthkitPlugin",
		"PurchasesPlugin",
		"SentryCapacitorPlugin"
	]
}
